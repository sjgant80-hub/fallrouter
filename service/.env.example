# FallRouter service · environment config (copy to .env; never commit)

# ─── auth ─────────────────────────────────────────────────────────
# Random hex string · clients present this as Authorization: Bearer <key>
# Generate: openssl rand -hex 32
FR_MASTER_KEY=sk-fallrouter-change-me

# ─── server ───────────────────────────────────────────────────────
FR_PORT=4100
FR_HOST=127.0.0.1                # bind to loopback · expose via reverse proxy if remote

# ─── routing policy ──────────────────────────────────────────────
# auto | always-local | always-frontier
FR_POLICY=auto

# ─── local leg (Ollama) ──────────────────────────────────────────
FR_LOCAL_URL=http://127.0.0.1:11434
FR_LOCAL_FEMTO=llama3.2:3b          # classify / route / yes-no (fast, small)
FR_LOCAL_NANO=llama3.1:8b           # write / explain (standard)
FR_LOCAL_MILLI=llama3.1:70b         # deep reasoning (falls back to nano if unavailable)

# ─── frontier leg (optional; leave empty to disable that provider) ─
FR_ANTHROPIC_KEY=
FR_ANTHROPIC_MODEL=claude-opus-4-8

FR_OPENAI_KEY=
FR_OPENAI_MODEL=gpt-4o

# ─── audit database ──────────────────────────────────────────────
FR_DB=./fallrouter.db
