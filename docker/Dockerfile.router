FROM node:20-alpine AS build

WORKDIR /app

# Install build tools for better-sqlite3
RUN apk add --no-cache python3 make g++

COPY package.json ./
COPY router.mjs ./

RUN npm install --omit=dev

# ─── runtime ──────────────────────────────────────────────────
FROM node:20-alpine

RUN apk add --no-cache wget curl

WORKDIR /app
COPY --from=build /app /app

RUN mkdir -p /data

EXPOSE 4100

CMD ["node", "router.mjs"]
