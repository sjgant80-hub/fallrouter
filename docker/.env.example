# Copy to .env and edit · never commit .env

# Random hex string (openssl rand -hex 32)
FR_MASTER_KEY=change-me-to-random-hex

# Routing policy · auto | always-local | always-frontier
FR_POLICY=auto

# Local model names (must match what Ollama can pull)
FR_LOCAL_FEMTO=llama3.2:3b
FR_LOCAL_NANO=llama3.1:8b
FR_LOCAL_MILLI=llama3.1:70b

# Frontier API keys (leave empty to disable that provider)
FR_ANTHROPIC_KEY=
FR_ANTHROPIC_MODEL=claude-opus-4-8

FR_OPENAI_KEY=
FR_OPENAI_MODEL=gpt-4o
